{
    "family": "node-express-staging",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::761836488860:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "app",
            "image": "REPLACE_AT_DEPLOY",
            "essential": true,
            "portMappings": [
                {"containerPort": 3000, "hostPort": 3000, "protocol":"tcp"}
            ],
            "environment": [
                {"name": "PORT", "value": "3000"}
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/node-express/staging",
                    "awslogs-region": "us-west-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ]
}